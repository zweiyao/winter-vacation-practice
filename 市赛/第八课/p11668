#include <iostream>
#include <cstring>
using namespace std;
int a[1000005], h[1000005];
int f[1000005];
int main()
{
  int n;
  cin >> n;
  for (int i = 1; i <= n; i++)
  {
    cin >> a[i];
    h[a[i]]++;
    if (h[a[i]] == 1)
      f[i] = f[i - 1] + 1;
    else
      f[i] = f[i - 1];
  }
  memset(h, 0, sizeof(h));
  long long ans = 0;
  for (int i = n; i >= 1; i--)
  {
    h[a[i]]++;
    if (h[a[i]] == 2)
      ans += f[i - 1];
  }
  for (int i = 1; i <= n; i++)
  {
    if (h[i] >= 3)
      ans--;
  }
  cout << ans << endl;
  return 0;
}